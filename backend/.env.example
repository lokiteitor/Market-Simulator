# Defaults de DESARROLLO — copiar a .env y ajustar.
# Nombres y valores según CONTRATOS_IMPLEMENTACION.md §3.

DATABASE_URL=postgres://market:market@localhost:5432/market
# Conexiones máximas del pool de Postgres por proceso (core y worker tienen
# cada uno el suyo). Subirlo solo si db_transactions_in_flight se clava en
# este valor con la duración de tx creciendo (panel "Pool de Postgres" en
# Grafana); el óptimo ronda 2-4x los cores de Postgres.
DB_POOL_MAX=10
# Prepared statements de postgres.js. true en dev (Postgres directo); poner
# false SOLO detrás de PgBouncer en modo transaction (ver infra/.env.docker).
DB_PREPARE=true
REDIS_URL=redis://localhost:6379
# DB lógica de Redis se selecciona por uso:
REDIS_PUBSUB_DB=0
REDIS_BULLMQ_DB=1
PORT=8000
METRICS_PORT=8001
WORKER_METRICS_PORT=8002
JWT_SECRET=dev-secret-change-me
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=604800
SIM_TIME_FACTOR=5
ORDER_TTL_MIN_SIM_SECONDS=60
ORDER_TTL_MAX_SIM_SECONDS=604800
FEE_FIXED_CENTS=5
FEE_RATE_BPS=25
# Tasa de consumo: fracción del fee ya cobrado que se desvía del banco a las
# ciudades (5000 = 50%). El salario se recicla SIEMPRE al 100% (no configurable).
CITY_FEE_SHARE_BPS=5000
MASTER_SEED=42
# Capital semilla subido (ADR-021 + ADR-022): `transformer` es ahora el ÚNICO
# rol productivo y cubre también la extracción, que ya no vive solo de salario:
# necesita capital circulante para comprar agua/semillas/fertilizante/piensos
# antes de producir, además de su 1ª instalación.
DEFAULT_SEED_CAPITAL_CENTS=400000
SEED_CAPITAL_TRANSFORMER_MIN_CENTS=600000
SEED_CAPITAL_TRANSFORMER_MAX_CENTS=1200000
SEED_CAPITAL_TRADER_MIN_CENTS=400000
SEED_CAPITAL_TRADER_MAX_CENTS=800000
SEED_AGENT_PASSWORD=dev-password-123
SEED_CONFIG_PATH=../infra/seed-config.json
# Ciudades-consumidor (rol `city`): lista canónica compartida con bots-ciudad.
# CITY_SEED_PASSWORD debe coincidir con `city_password` de bots-ciudad/config.yaml.
CITY_CONFIG_PATH=../infra/cities.json
CITY_SEED_PASSWORD=city-dev-password
# Capital semilla por unidad de population_weight (Tokyo 37400 → 1.870.000 centavos).
CITY_SEED_CAPITAL_CENTS_PER_WEIGHT=50
# Patrón oro. La paridad se deriva en el seed:
#   parity = floor(M0 * GOLD_COVERAGE_RATIO_BPS / (100 * D))  [cents por unidad de oro]
# donde M0 = capital total sembrado y D = yacimiento sorteado en
# [GOLD_DEPOSIT_MIN_QTY_CENT, GOLD_DEPOSIT_MAX_QTY_CENT] con MASTER_SEED.
# Calibracion (ADR-022): el window_bid debe superar el COSTE DE PRODUCCION del
# oro, o minar deja de rentar y se para la acunacion (los registros dinamicos
# empiezan a fallar con insufficient_gold_backing). Con este .env: coste 820
# c/kg (salario 14400 + 2000 L de agua, / 20 kg) frente a un window_bid de
# ~190.000-353.000 c/kg segun el yacimiento sorteado, porque M0 lo domina
# GOLD_BANK_INITIAL_CAPITAL_CENTS. Margen de sobra, pero es la restriccion a
# revisar si se sube el consumo de mineria_oro o se baja el capital del banco.
BANK_USERNAME=central_bank
GOLD_PRODUCT_KEY=oro
GOLD_DEPOSIT_MIN_QTY_CENT=70000000             # 700.000 kg
GOLD_DEPOSIT_MAX_QTY_CENT=130000000            # 1.300.000 kg
GOLD_COVERAGE_RATIO_BPS=10000
GOLD_WINDOW_SPREAD_BPS=500
GOLD_BANK_INITIAL_RESERVE_BPS=2000
GOLD_BANK_INITIAL_CAPITAL_CENTS=1300000000     # 13 M$ (mínimo teórico: ~11,9 M$)
# Yacimientos finitos genericos (ADR-023). Los recursos NO renovables marcados
# `finite: true` en infra/seed-config.json (los 15 geologicos: hierro, carbon,
# petroleo, litio...) reciben un yacimiento cuyo tamano se sortea en
# EJECUCIONES de su receta con MASTER_SEED y se convierte a qty_cent
# multiplicando por su output. El rango por defecto es el presupuesto implicito
# del yacimiento de oro (28.000-52.000 ejecuciones), para que todos los recursos
# duren lo mismo en dias-linea.
DEPOSIT_MIN_EXECUTIONS=28000
DEPOSIT_MAX_EXECUTIONS=52000
# Rendimiento decreciente: una receta con yacimiento rinde
# max(DEPOSIT_YIELD_FLOOR_BPS, remanente/inicial) de su output nominal. El mismo
# salario e insumos se reparten entre menos unidades, asi que el coste unitario
# sube solo y el mercado reasigna produccion antes de que el recurso se agote.
# 10000 desactiva el decrecimiento (corte seco al llegar a 0).
# Vida real del yacimiento con el suelo al 25%: ~2,4x las ejecuciones sorteadas
# (la cola es larga a proposito, como la de una mina moribunda).
# Efecto sobre el ORO: en el suelo su coste sube de 820 a 3.280 c/kg, aun 60-100x
# por debajo del window_bid, asi que la calibracion de la acunacion no cambia.
DEPOSIT_YIELD_FLOOR_BPS=2500

TRANSFORMATION_SWEEP_INTERVAL_MS=10000
ORDER_EXPIRY_SWEEP_INTERVAL_MS=5000
# Sweeper que pliega fee_ledger al capital del banco (ADR-019).
FEE_LEDGER_SWEEP_INTERVAL_MS=5000
# Reparto del ingreso recurrente de las ciudades (flujo circular).
CITY_INCOME_SWEEP_INTERVAL_MS=5000
SWEEP_BATCH_SIZE=100
IDEMPOTENCY_TTL_SECONDS=600
RECONNECT_EVENTS_LIMIT=100
LOG_LEVEL=info
NODE_ENV=development
