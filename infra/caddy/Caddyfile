:9080 {
    # 1. Configuración de CORS
    @options {
        method OPTIONS
    }
    header {
        Access-Control-Allow-Origin *
        Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS, HEAD, PATCH"
        Access-Control-Allow-Headers "Content-Type, Authorization, X-Requested-With, Accept, Origin"
        Access-Control-Expose-Headers *
        Access-Control-Max-Age 3600
        defer
    }
    respond @options "" 204

    # 2. Proxy inverso balanceado a las N réplicas del core (ADR-019).
    #    `dynamic a` re-resuelve el DNS interno de Docker (que devuelve una IP
    #    por réplica) cada 5s, así el balanceo se adapta al escalado sin listar
    #    upstreams a mano. WS (/v1/ws) se balancea igual: NO hacen falta sticky
    #    sessions porque el fan-out va por Redis pub/sub.
    @v1 {
        path /v1/*
    }
    reverse_proxy @v1 {
        dynamic a {
            name core
            port 8000
            refresh 5s
        }
        lb_policy round_robin
        transport http {
            dial_timeout 60s
        }
    }
}
